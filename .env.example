# Database Connection Strings
# Direct/Session Connection (used for migrations via drizzle-kit)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/visual_flow"

# Connection Pooling (used for runtime application queries)
DATABASE_URL_POOL="postgresql://postgres:postgres@localhost:5432/visual_flow?pga_max_connections=10"

# Authentication Settings (Better Auth)
# Generate a random secret using: openssl rand -hex 32
BETTER_AUTH_SECRET="your_better_auth_secret_here"
BETTER_AUTH_URL="http://localhost:3000"

# Public App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Realtime Client Credentials (used for Realtime Broadcast Channels)
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key_here"
